# Copia questo file in .env e compila i valori.

ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
DATABASE_URL=

# Chiave statica per proteggere tutte le rotte /api/* (tranne /api/health).
# Genera un valore casuale robusto, es.: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_API_KEY=

# Stessa chiave sopra, esposta al build del frontend (Vite la inietta nel bundle
# pubblico: non è un segreto reale una volta pubblicato il sito, vedi note in
# AUDIT_BANDI_SCANNER.md D-3). Deve avere lo stesso valore di APP_API_KEY.
VITE_APP_API_KEY=

# Limite richieste di estrazione per IP (facoltativi, hanno un default sensato)
ESTRAZIONE_RATE_LIMIT_MAX=10
ESTRAZIONE_RATE_LIMIT_WINDOW_SECONDS=3600
